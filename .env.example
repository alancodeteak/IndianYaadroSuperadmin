APP_NAME=Yadro Superadmin API
APP_VERSION=0.1.0
ENVIRONMENT=development

DATABASE_URL=postgresql://user:password@host:5432/db
SECRET_KEY=replace-with-min-32-char-random-secret

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ISSUER=yaadro-superadmin
JWT_AUDIENCE=yaadro-superadmin-clients

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

ADMIN_API_KEY=replace-with-strong-admin-api-key
METRICS_API_KEY=replace-with-strong-metrics-api-key
ENABLE_ADMIN_API_KEY_PROTECTION=true
ENABLE_METRICS_API_KEY_PROTECTION=true

# AWS / S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_ACCOUNT_ID=185187792899
AWS_S3_KMS_KEY_ID=alias/production-yadro-s3-key
S3_PRESIGNED_URL_EXPIRY=3600
S3_MAX_FILE_SIZE=10485760
PROD_S3_BUCKET_DELIVERY_PARTNER=production-yadro-delivery-partners-185187792899-ap-south-1
PROD_S3_BUCKET_ORDERS=production-yadro-orders-185187792899-ap-south-1
PROD_S3_BUCKET_TICKETS=production-yadro-tickets-185187792899-ap-south-1
PROD_S3_BUCKET_SHOP_OWNER=production-yadro-shop-owners-185187792899-ap-south-1

TZ=Asia/Kolkata

