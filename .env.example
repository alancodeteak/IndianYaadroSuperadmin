APP_NAME=Yadro Superadmin API
APP_VERSION=0.1.0
ENVIRONMENT=development

DATABASE_URL=sqlite+pysqlite:///./superadmin.db
SECRET_KEY=replace-with-min-32-char-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ISSUER=yaadro-superadmin
JWT_AUDIENCE=yaadro-superadmin-clients

OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=10
OTP_LOG_TO_TERMINAL=false
ADMIN_OTP_EMAILS=yaadro@codeteak.com
PORTAL_OTP_EMAILS=yaadro@codeteak.com
SMTP_ENABLED=true
SMTP_SECURE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yaadro@codeteak.com
SMTP_PASS=mmzm oqtq ylpz lxwx
SMTP_USERNAME=yaadro@codeteak.com
SMTP_PASSWORD=mmzm oqtq ylpz lxwx
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=yaadro@codeteak.com
SMTP_FROM_NAME=Yadro Superadmin
MONITOR_APP_PASSWORD=yaadro@1234
SHOP_ID_PASSWORD=shopyaadro@1234

REDIS_URL=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
FORCE_HTTPS_REDIRECT=false
ENABLE_RATE_LIMIT=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

ADMIN_API_KEY=replace-with-strong-admin-api-key
METRICS_API_KEY=replace-with-strong-metrics-api-key
ENABLE_ADMIN_API_KEY_PROTECTION=true
ENABLE_METRICS_API_KEY_PROTECTION=true
ENABLE_DETAILED_HEALTH=false
